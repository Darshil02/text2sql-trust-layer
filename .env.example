# Required: Groq powers both the SQL generator (Llama 3.3) and the independent judge (gpt-oss)
GROQ_API_KEY=

# Optional: present in the skeleton, not used by the default pipeline
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: LangSmith tracing. Leave disabled unless you have a key.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=trust-sql
